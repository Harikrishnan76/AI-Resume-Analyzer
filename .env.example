# ──────────────────────────────────────────────
# AI Resume Analyzer — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in values.

# ── App Settings ──
SECRET_KEY=change-me-to-a-random-secret-string
APP_NAME="AI Resume Analyzer"
# Set to false in production to send real emails instead of saving them to disk.
DEBUG=true

# ── Database ──
# SQLite (default for MVP)
DATABASE_URL=sqlite+aiosqlite:///./data/resume_analyzer.db

# ── File Storage ──
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Authentication ──
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ── Email Configuration ──
# Option A: Standard SMTP (e.g. Mailhog, Gmail, custom mail servers)
# To use Gmail SMTP:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USERNAME=your-gmail@gmail.com
#   SMTP_PASSWORD=your-gmail-app-password (must generate an App Password in Gmail Security settings)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@resumeanalyzer.local
SMTP_USE_TLS=false

# Option B: Modern HTTP APIs (Recommended fallback for 100% deliverability & simple setup)
# Leave blank to use standard SMTP configuration instead.
RESEND_API_KEY=
SENDGRID_API_KEY=

# ── OpenAI (optional — enables LLM-assisted extraction) ──
# Leave blank to use traditional parsing only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Scoring ──
SCORE_WEIGHT_KEYWORD=0.40
SCORE_WEIGHT_EMBEDDING=0.40
SCORE_WEIGHT_RULES=0.20
EMBEDDING_MODEL=all-MiniLM-L6-v2
SHORTLIST_THRESHOLD=0.65
